# IDE folders
.idea/
.vs/

# Caches
__pycache__
.mypy_cache
.cache/

# Original files
orig/*/*
!orig/*/.gitkeep
*.dol
*.rel
*.elf
*.o
*.map
*.MAP

# Build files
build/
.ninja_*
.ninja-build.lock
build.ninja

# decompctx output
ctx.*
*.ctx

# Generated configs
objdiff.json
compile_commands.json

# Miscellaneous
/*.txt
*.exe

# wibo/cl.exe scratch files (linker temp output left in cwd)
/_CL_*

# .claude/ holds subagent worktrees + transient state; allow skills + settings.json
# (NB: use /* not / so git still recurses into .claude/ to find skills/)
.claude/*
!.claude/skills/
!.claude/settings.json
.claude/settings.local.json

# Native port build output
native/build/
native/build-*/
core
core.*

# fingerprint_match.py generated indexes (regenerable from build/ + source trees)
/fingerprints.json
/autoid.json
/unified_id.json
/proposed_splits_bindiff.txt
/proposed_splits_bindiff.spotcheck.csv
# bindiff_match.json is harvested from Ghidra + BinDiff (~10 min run); regenerable, large (~3.6 MB)
/tools/bindiff_match.json
/tools/.cache/

# Orchestrator MCP databases (regenerable via scripts/ingest_report.py)
/decomp.db
/decomp.db-journal
/decomp.db-wal
/decomp.db-shm
/struct_db.sqlite
/cache.db
/permuter_cache.db
/.scan_cache.db
/strategy.db

# Shared venv (symlink to ../dc3-decomp/venv)
/venv

# Machine-specific symlink to the local objdiff fork (create via: ln -s <abs>/objdiff-cli bin/)
/bin/objdiff-cli

# Ghidra projects (large; rebuild via tools/ghidra/import-xex.sh)
/ghidra_projects/
